# Provider master gates
REAL_PROVIDER_ENABLED=false
M1_REAL_PROVIDER=mock
M1_REAL_PROVIDER_EXECUTION_ALLOWED=false
M1_REAL_PROVIDER_COST_ACK=false

# RunningHub.cn primary real provider
RUNNINGHUB_API_KEY=
RUNNINGHUB_API_BASE_URL=https://www.runninghub.cn
RUNNINGHUB_MODEL_API_ENDPOINT=/openapi/v2/rhart-video-g/image-to-video

# Runway secondary fallback provider port
RUNWAYML_API_SECRET=
RUNWAYML_API_BASE_URL=https://api.dev.runwayml.com
RUNWAYML_API_VERSION=2024-11-06

# Optional local behavior
AI_VIDEO_NODE22_PATH=ops/tools/node-v22.23.1-win-x64/node.exe
AI_VIDEO_WORKBENCH_RUNTIME_ROOT=ops/tools/workbench-runtime
AI_VIDEO_WORKSPACE_DB_PATH=data/app.sqlite
H1_WORKBENCH_PORT=4181
PROVIDER_OUTPUT_DOWNLOAD_TIMEOUT_MS=120000
PROVIDER_TASK_POLL_INTERVAL_MS=5000
PROVIDER_TASK_POLL_TIMEOUT_MS=600000

# WebGPT V4 local MCP resource server. Values remain explicit process configuration; this file is never auto-loaded.
WEBGPT_V4_MCP_PORT=2091
WEBGPT_V4_MEDIA_PORT=2092
WEBGPT_V4_PROFILE=readonly
WEBGPT_V4_WIDGET_DOMAIN=
WEBGPT_V4_TELEMETRY_MODE=off
# Common OAuth resource identifier; the Readonly audience must match this value exactly
WEBGPT_V4_RESOURCE_URL=
# Readonly provider-neutral Federated OAuth (configure all four values together)
# Jenn owner-only Auth0/predefined-client route is accepted; any replacement or multi-user expansion requires a new gate.
WEBGPT_V4_READONLY_OAUTH_ISSUER=
WEBGPT_V4_READONLY_OAUTH_AUDIENCE=
WEBGPT_V4_READONLY_OAUTH_JWKS_URI=
# Explicitly choose predefined, cimd, or dcr when configuring Readonly OAuth; PR3 fixture uses predefined
WEBGPT_V4_READONLY_OAUTH_CLIENT_REGISTRATION=
# Legacy Descope adapter retained for one version; do not combine with generic Readonly keys
WEBGPT_V4_DESCOPE_ISSUER=
WEBGPT_V4_DESCOPE_AUDIENCE=
WEBGPT_V4_DESCOPE_JWKS_URI=
WEBGPT_V4_DESCOPE_AUTHORIZATION_SERVER_URL=
# Full local-only OAuth (legacy single-user Auth0 boundary)
WEBGPT_V4_AUTH0_ISSUER=
WEBGPT_V4_AUTH0_AUDIENCE=
WEBGPT_V4_AUTH0_JWKS_URI=
WEBGPT_V4_ALLOWED_SUBJECT_SHA256=
WEBGPT_V4_MEDIA_PUBLIC_ORIGIN=
WEBGPT_V4_MEDIA_AUTH_COOKIE_NAME=__Host-webgpt_v4_media
FFMPEG_PATH=
FFPROBE_PATH=

# ChatGPT Director OAuth is a separate protected resource. Configure all five values together.
# It must not reuse WEBGPT_V4_RESOURCE_URL; no Director resource is enabled by these blank examples.
WEBGPT_DIRECTOR_RESOURCE_URL=
WEBGPT_DIRECTOR_OAUTH_ISSUER=
WEBGPT_DIRECTOR_OAUTH_AUDIENCE=
WEBGPT_DIRECTOR_OAUTH_JWKS_URI=
WEBGPT_DIRECTOR_OAUTH_CLIENT_REGISTRATION=
WEBGPT_DIRECTOR_REMOTE_ORIGIN=
WEBGPT_DIRECTOR_BRIDGE_KEY_ID=
WEBGPT_DIRECTOR_BRIDGE_KEY_B64=

# Future single ChatGPT Workspace connector. This OAuth resource is independent
# from legacy Readonly and Director routes; configure all five values together.
# Its audience and resource URL must match exactly and must not reuse either
# legacy resource. Blank examples do not enable the unified runtime.
WEBGPT_WORKSPACE_RESOURCE_URL=
WEBGPT_WORKSPACE_OAUTH_ISSUER=
WEBGPT_WORKSPACE_OAUTH_AUDIENCE=
WEBGPT_WORKSPACE_OAUTH_JWKS_URI=
WEBGPT_WORKSPACE_OAUTH_CLIENT_REGISTRATION=
# Verification material for the independent unified Snapshot transport. It is
# public; the private Ed25519 publisher key stays DPAPI-protected on Windows.
WEBGPT_WORKSPACE_PUBLISHER_KEY_ID=
WEBGPT_WORKSPACE_PUBLISHER_PUBLIC_KEY_B64=

# Remote Readonly MCP App runtime (Render; public verification material only)
WEBGPT_CLOUD_PUBLISHER_KEY_ID=
WEBGPT_CLOUD_PUBLISHER_PUBLIC_KEY_B64=

# Remote Readonly media capability bridge candidate (active key is a Render secret; never commit a value)
# Code/config presence does not mean the public Cloudflare playback route has passed acceptance.
WEBGPT_MEDIA_GATEWAY_ORIGIN=
TUNNEL_TRANSPORT_PROTOCOL=auto
WEBGPT_MEDIA_CAPABILITY_ACTIVE_KID=
WEBGPT_MEDIA_CAPABILITY_ACTIVE_KEY_B64URL=
# Optional bounded rotation window (all four previous-key fields are required together)
WEBGPT_MEDIA_CAPABILITY_PREVIOUS_KID=
WEBGPT_MEDIA_CAPABILITY_PREVIOUS_KEY_B64URL=
WEBGPT_MEDIA_CAPABILITY_PREVIOUS_ACCEPTED_FROM=
WEBGPT_MEDIA_CAPABILITY_PREVIOUS_ACCEPTED_UNTIL=

# Local readonly media operations (Git-ignored profile; secrets remain DPAPI-protected)
READONLY_MEDIA_OPERATIONS_PROFILE_PATH=data/webgpt/media-gateway/profile.json

# Local Human Workbench personal readonly operations (non-secret Git-ignored profile path)
WEBGPT_READONLY_PUBLISHER_PROFILE_PATH=data/webgpt/publisher/profile.json
