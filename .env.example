# Provider master gates
REAL_PROVIDER_ENABLED=false
M1_REAL_PROVIDER=mock
M1_REAL_PROVIDER_EXECUTION_ALLOWED=false
M1_REAL_PROVIDER_COST_ACK=false

# RunningHub.cn primary real provider
RUNNINGHUB_API_KEY=
RUNNINGHUB_API_BASE_URL=https://www.runninghub.cn
RUNNINGHUB_MODEL_API_ENDPOINT=/openapi/v2/rhart-video-g/image-to-video

# Runway secondary fallback provider port
RUNWAYML_API_SECRET=
RUNWAYML_API_BASE_URL=https://api.dev.runwayml.com
RUNWAYML_API_VERSION=2024-11-06

# Optional local behavior
PROVIDER_OUTPUT_DOWNLOAD_TIMEOUT_MS=120000
PROVIDER_TASK_POLL_INTERVAL_MS=5000
PROVIDER_TASK_POLL_TIMEOUT_MS=600000

# WebGPT V4 local MCP resource server (configure only after external authorization)
WEBGPT_V4_MCP_PORT=2091
WEBGPT_V4_MEDIA_PORT=2092
WEBGPT_V4_AUTH0_ISSUER=
WEBGPT_V4_AUTH0_AUDIENCE=
WEBGPT_V4_AUTH0_JWKS_URI=
WEBGPT_V4_RESOURCE_URL=
WEBGPT_V4_ALLOWED_SUBJECT_SHA256=
WEBGPT_V4_MEDIA_PUBLIC_ORIGIN=
WEBGPT_V4_WIDGET_ORIGIN=
WEBGPT_V4_MEDIA_AUTH_COOKIE_NAME=__Host-webgpt_v4_media
FFMPEG_PATH=A:\AI-VIDEO\ffmpeg\bin\ffmpeg.exe
