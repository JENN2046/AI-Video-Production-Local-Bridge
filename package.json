{
  "name": "ai-video-production-workspace",
  "version": "0.0.0-m0",
  "private": true,
  "type": "module",
  "description": "M0 mock-provider-first video production loop skeleton.",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:m0": "npm run build && node --test dist/tests/m0-*.test.js",
    "demo:m0": "npm run build && node dist/scripts/demo-m0.js",
    "closeout:m0": "npm run build && node dist/scripts/closeout-m0.js",
    "test:m1-0": "npm run build && node --test dist/tests/m1-0-external-image-transfer.test.js",
    "demo:m1-0": "npm run build && node dist/scripts/demo-m1-0.js",
    "closeout:m1-0": "npm run build && node dist/scripts/closeout-m1-0.js",
    "test:m1": "npm run build && node --test dist/tests/m1-provider-boundary.test.js",
    "demo:m1": "npm run build && node dist/scripts/demo-m1.js",
    "closeout:m1": "npm run build && node dist/scripts/closeout-m1.js",
    "runway:canary": "npm run build && node dist/scripts/runway-canary.js",
    "demo:m1:canary": "npm run runway:canary",
    "gpt:handoff:app": "npm run build && node dist/scripts/gpt-handoff-app.js",
    "test:gpt:handoff": "npm run build && node --test dist/tests/gpt-handoff-app.test.js",
    "demo:gpt:handoff": "npm run build && node dist/scripts/demo-gpt-handoff.js",
    "g0:r1:import-prep": "npm run build && node dist/scripts/g0-r1-import-prep.js",
    "g0:r1:freeze": "npm run build && node dist/scripts/g0-r1-package-freeze.js",
    "g0:r1:full": "npm run build && node dist/scripts/g0-r1-import-prep.js && node dist/scripts/g0-r1-package-freeze.js",
    "h1:workbench": "npm run build && node dist/scripts/h1-workbench.js",
    "test:h1": "npm run build && node --test dist/tests/h1-workbench.test.js",
    "test:m1:real": "npm run build && node dist/scripts/test-m1-real.js",
    "demo:m1:real": "npm run build && node dist/scripts/demo-m1-real.js",
    "test:g0": "npm run build && node --test dist/tests/g0-pregen.test.js dist/tests/provider-env-secret-safety.test.js",
    "demo:g0": "npm run build && node dist/scripts/demo-g0.js",
    "closeout:g0": "npm run build && node dist/scripts/closeout-g0.js",
    "demo:g0:app-ready": "npm run demo:g0",
    "closeout:g0:app-ready": "npm run closeout:g0",
    "env:check": "npm run build && node dist/scripts/env-check.js",
    "provider:preflight": "npm run build && node dist/scripts/provider-preflight.js",
    "secret:scan": "npm run build && node dist/scripts/secret-scan.js",
    "closeout:provider-env": "npm run build && node dist/scripts/closeout-provider-env.js",
    "closeout:t00": "npm run build && node dist/scripts/closeout-t00.js",
    "closeout:pregen": "npm run build && node dist/scripts/closeout-pregen-final.js",
    "m0:reset": "npm run build && node dist/scripts/m0-reset.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
